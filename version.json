$data = json_decode(file_get_contents($jsonUrl), true);

$version = $data['latest_version'] ?? '1.0.0';
$downloadUrl = $data['download_url'] ?? '#';
$infoUrl = $data['info_url'] ?? '#';

$releaseDate = date("F d, Y");

?>

